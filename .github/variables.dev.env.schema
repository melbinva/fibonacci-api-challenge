# Dev Stage Variables (GitHub -> Settings -> Secrets and variables -> Actions -> Variables)

DEV_AKS_RESOURCE_GROUP=rg-fibonacci-dev
DEV_AKS_CLUSTER_NAME=aks-fibonacci-dev
DEV_AKS_NAMESPACE=fibonacci-dev
DEV_AKS_DEPLOYMENT_NAME=fibonacci-api
DEV_AKS_CONTAINER_NAME=fibonacci-api
DEV_INGRESS_HOST=fibonacci-dev.example.com
DEV_USER_ASSIGNED_MANAGED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
DEV_KEY_VAULT_NAME=kv-fibonacci-dev
DEV_AKV_TLS_CERT_SECRET_NAME=fibonacci-api-tls-crt
DEV_AKV_TLS_KEY_SECRET_NAME=fibonacci-api-tls-key

# Optional URL for post-deployment HTTP validation (set empty to skip curl check)
DEV_AKS_VALIDATION_URL=https://fibonacci-dev.example.com/health
