# Test Stage Variables (GitHub -> Settings -> Secrets and variables -> Actions -> Variables)

TEST_AKS_RESOURCE_GROUP=rg-fibonacci-test
TEST_AKS_CLUSTER_NAME=aks-fibonacci-test
TEST_AKS_NAMESPACE=fibonacci-test
TEST_AKS_DEPLOYMENT_NAME=fibonacci-api
TEST_AKS_CONTAINER_NAME=fibonacci-api
TEST_INGRESS_HOST=fibonacci-test.example.com
TEST_USER_ASSIGNED_MANAGED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
TEST_KEY_VAULT_NAME=kv-fibonacci-test
TEST_AKV_TLS_CERT_SECRET_NAME=fibonacci-api-tls-crt
TEST_AKV_TLS_KEY_SECRET_NAME=fibonacci-api-tls-key

# Optional URL for post-deployment HTTP validation (set empty to skip curl check)
TEST_AKS_VALIDATION_URL=https://fibonacci-test.example.com/health
